"
GtRsrWithProxyWireSerializationStrategy provides the same functionality as its parent class, but having the separate name allows clients to choose whether to retrieve objects by value (wire serialisation) or with the object's associated proxy.
"
Class {
	#name : #GtRsrRemoteObjectWireSerializationStrategy,
	#superclass : #GtRsrWireSerializationStrategy,
	#category : #'GToolkit-GemStone'
}
